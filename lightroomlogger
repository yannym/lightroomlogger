<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lightroom Classic Session Tracker</title>
  <!-- Load Tailwind CSS from CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Configure Tailwind to match Lightroom's exact UI scheme -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            lrDarkest: '#111214',
            lrDarkBg: '#151719',
            lrPanel: '#1a1c1f',
            lrBorder: '#25282d',
            lrBorderLight: '#353a42',
            lrBlue: '#31a8ff',
            lrBlueHover: '#52b8ff',
            lrMuted: '#8e94a0',
          }
        }
      }
    }
  </script>
  <!-- Import elegant Inter font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    /* Sleek custom scrollbars to match professional darkroom interfaces */
    ::-webkit-scrollbar {
      width: 6px;
      height: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #111214;
    }
    ::-webkit-scrollbar-thumb {
      background: #2c323d;
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: #31a8ff;
    }
  </style>
</head>
<body class="min-h-screen bg-lrDarkest text-[#d2d5da] flex flex-col antialiased select-none">

  <!-- HEADER BAR -->
  <header class="border-b border-lrBorder bg-lrPanel px-6 py-4 flex items-center justify-between shadow-md z-10">
    <div class="flex items-center space-x-3">
      <div class="bg-lrBlue text-slate-900 p-2 rounded-lg font-bold flex items-center justify-center">
        <!-- Sliders Icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="21" x2="4" y2="14"></line><line x1="4" y1="10" x2="4" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="12"></line><line x1="12" y1="8" x2="12" y2="3"></line>
          <line x1="20" y1="21" x2="20" y2="16"></line><line x1="20" y1="12" x2="20" y2="3"></line>
          <line x1="1" y1="14" x2="7" y2="14"></line><line x1="9" y1="8" x2="15" y2="8"></line>
          <line x1="17" y1="16" x2="23" y2="16"></line>
        </svg>
      </div>
      <div>
        <h1 class="text-base font-bold tracking-tight text-white flex items-center gap-2">
          Lightroom Classic Session Tracker
          <span class="text-[10px] bg-lrBlue/20 text-lrBlue font-bold px-2 py-0.5 rounded-full uppercase tracking-wider">macOS Overlay</span>
        </h1>
        <p class="text-[11px] text-lrMuted">Optimize, log, and audit your darkroom photography workflow</p>
      </div>
    </div>

    <div class="flex items-center space-x-2">
      <button onclick="openManualLogModal()" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs bg-lrBorder hover:bg-lrBorderLight border border-lrBorderLight text-gray-300 font-medium transition">
        <!-- History Icon -->
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline><line x1="12" y1="7" x2="12" y2="12"></line><line x1="12" y1="12" x2="14" y2="14"></line></svg>
        Manual Log
      </button>
      
      <button onclick="openNewGalleryModal()" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs bg-gradient-to-r from-lrBlue to-[#1d8be0] hover:from-lrBlueHover hover:to-[#2297f0] text-slate-950 font-bold shadow-lg shadow-lrBlue/10 transition">
        <!-- Plus Icon -->
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        New Gallery
      </button>
    </div>
  </header>

  <!-- CORE WORKSPACE -->
  <div class="flex-1 flex overflow-hidden">
    
    <!-- LEFT BAR: Gallery Directory -->
    <aside class="w-72 border-r border-lrBorder bg-lrDarkBg flex flex-col shrink-0 overflow-y-auto">
      <div class="p-4 border-b border-[#22252a] flex items-center justify-between shrink-0">
        <span class="text-[10px] font-semibold uppercase tracking-wider text-[#727a87]">Active Catalog Galleries</span>
        <span class="text-[10px] text-lrBlue font-semibold bg-lrBlue/10 px-1.5 py-0.5 rounded">Local DB</span>
      </div>

      <!-- Directory list target -->
      <div id="galleryDirectory" class="flex-1 p-2 space-y-1">
        <!-- Dynamic injections go here -->
      </div>

      <!-- Footnote instruction -->
      <div class="p-3 bg-lrDarkest border-t border-[#22252a] text-center text-[10px] text-gray-500 shrink-0">
        Use side controls to manage imports, editing presets, and culling sessions.
      </div>
    </aside>

    <!-- MAIN PANEL -->
    <main class="flex-1 flex flex-col bg-[#16181b] overflow-y-auto">
      
      <!-- GALLERY OVERVIEW CARD -->
      <section class="bg-lrPanel p-5 border-b border-lrBorder flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="space-y-1">
          <div class="flex items-center gap-2">
            <span class="text-[9px] tracking-widest font-bold text-lrMuted uppercase">Active Catalog Target</span>
            <span id="activeGalleryIdTag" class="bg-slate-800 text-gray-300 text-[9px] font-mono px-1.5 py-0.5 rounded"></span>
          </div>
          <h2 id="activeGalleryName" class="text-xl font-black text-white tracking-tight">Loading Gallery...</h2>
          
          <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-xs text-[#828a99] pt-1">
            <span class="flex items-center gap-1.5">
              <svg class="text-gray-500" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path></svg>
              Client: <strong id="activeGalleryClient" class="text-gray-300">N/A</strong>
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="text-gray-500" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
              Batch: <strong id="activeGalleryPhotos" class="text-gray-300">0</strong>
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="text-emerald-500" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
              Rate: <strong id="activeGalleryRate" class="text-emerald-400">$0/hr</strong>
            </span>
          </div>
        </div>

        <div class="flex items-center gap-1.5 shrink-0">
          <button onclick="openEditGalleryModal()" class="px-2.5 py-1.5 text-xs bg-lrBorder hover:bg-lrBorderLight text-gray-300 border border-lrBorderLight rounded transition flex items-center gap-1">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"></path></svg>
            Edit
          </button>
          <button onclick="exportData()" class="px-2.5 py-1.5 text-xs bg-lrBorder hover:bg-lrBorderLight text-lrBlue border border-lrBlue/20 rounded transition flex items-center gap-1" title="Export Logs as JSON">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            Export JSON
          </button>
          <button onclick="deleteActiveGallery()" class="p-1.5 text-xs bg-rose-950/20 hover:bg-rose-900/30 text-rose-400 border border-rose-500/15 rounded transition" title="Delete Gallery">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
          </button>
        </div>
      </section>

      <!-- ACTIVE STOPWATCH TIMER MODULE -->
      <section class="p-5 bg-gradient-to-r from-[#171a1f] to-lrDarkest border-b border-lrBorder relative overflow-hidden shrink-0">
        <div class="absolute top-0 right-0 w-64 h-64 bg-lrBlue/5 rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="max-w-6xl mx-auto flex flex-col lg:flex-row lg:items-center justify-between gap-5 relative z-10">
          
          <!-- Timer Left: Phase Selection buttons -->
          <div class="space-y-2 flex-1">
            <div class="flex items-center gap-2">
              <span id="pulsingDot" class="w-2 h-2 rounded-full bg-zinc-600"></span>
              <span class="text-[10px] uppercase font-bold text-lrMuted tracking-wider">Live System Engine</span>
            </div>
            <h3 class="text-xs font-semibold text-gray-400">Select active Lightroom processing phase:</h3>
            
            <div class="grid grid-cols-2 sm:grid-cols-5 gap-1.5 pt-1" id="phasesGrid">
              <!-- Phases injected dynamically here -->
            </div>
          </div>

          <!-- Timer Center Right: Big Counter -->
          <div class="bg-[#1d2025] p-4 rounded-xl border border-[#2b303a] flex flex-col sm:flex-row items-center gap-5 justify-center lg:justify-end min-w-[290px]">
            <div class="text-center sm:text-right">
              <div id="timerPhaseTitle" class="text-[9px] text-gray-500 uppercase font-mono tracking-widest mb-1">
                IMPORT TIMER
              </div>
              <div id="timerDisplay" class="font-mono text-3xl font-black text-white tracking-widest">
                00:00:00
              </div>
              <div class="text-[9px] text-gray-400 mt-1">
                Segment cumulative: <span id="segmentTotalDisplay" class="font-mono text-lrBlue font-bold">0m</span>
              </div>
            </div>

            <!-- Controls -->
            <div class="flex items-center gap-1.5">
              <button id="btnPlayPause" onclick="toggleTimer()" class="p-3.5 rounded-lg bg-lrBlue hover:bg-lrBlueHover text-slate-950 flex items-center justify-center shadow-lg transition active:scale-95" title="Start Tracking">
                <svg id="playPauseIcon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2"><polygon points="6 3 20 12 6 21 6 3"></polygon></svg>
              </button>

              <button id="btnSaveTime" onclick="saveActiveTimerSegment()" disabled class="p-3.5 rounded-lg bg-emerald-500/10 text-emerald-500 border border-emerald-500/20 flex items-center justify-center opacity-40 cursor-not-allowed transition" title="Log Session to Phase">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
              </button>

              <button id="btnResetTimer" onclick="resetTimer()" disabled class="p-2.5 rounded-lg text-zinc-600 hover:text-rose-400 transition" title="Discard Current Timer">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
              </button>
            </div>
          </div>

        </div>
      </section>

      <!-- STATS DASHBOARD BAR -->
      <section class="px-6 py-3.5 bg-lrDarkest border-b border-lrBorder grid grid-cols-2 sm:grid-cols-4 gap-4 shrink-0 shadow-inner">
        
        <div class="flex items-center gap-2.5">
          <div class="p-2 rounded bg-indigo-500/10 text-indigo-400 border border-indigo-500/20">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <div>
            <span class="text-[9px] text-gray-500 uppercase block font-semibold">Total Session Hours</span>
            <span id="statTotalTime" class="font-mono text-sm font-bold text-white">0h 0m</span>
          </div>
        </div>

        <div class="flex items-center gap-2.5">
          <div class="p-2 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
          </div>
          <div>
            <span class="text-[9px] text-gray-500 uppercase block font-semibold">Editing Value Earned</span>
            <span id="statTotalCost" class="font-mono text-sm font-bold text-emerald-400">$0.00</span>
          </div>
        </div>

        <div class="flex items-center gap-2.5">
          <div class="p-2 rounded bg-amber-500/10 text-amber-400 border border-amber-500/20">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
          </div>
          <div>
            <span class="text-[9px] text-gray-500 uppercase block font-semibold">Speed Per Photo</span>
            <span id="statSpeed" class="font-mono text-sm font-bold text-white">0s / edit</span>
          </div>
        </div>

        <div class="flex items-center gap-2.5">
          <div class="p-2 rounded bg-pink-500/10 text-pink-400 border border-pink-500/20">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <div>
            <span class="text-[9px] text-gray-500 uppercase block font-semibold">Checks Completed</span>
            <span id="statTasks" class="font-mono text-sm font-bold text-white">0 / 0</span>
          </div>
        </div>

      </section>

      <!-- TWO-COLUMN WORKSPACE GRID -->
      <div class="p-6 grid grid-cols-1 lg:grid-cols-12 gap-6 max-w-7xl w-full mx-auto">
        
        <!-- COLUMN 1: MILESTONES & ACTIVE PHASE CHECKLISTS -->
        <div class="lg:col-span-7 space-y-4">
          <div class="flex items-center justify-between pb-1">
            <h4 class="text-xs font-bold uppercase tracking-wider text-lrMuted flex items-center gap-1.5">
              <svg class="text-lrBlue" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polygon points="2 17 12 22 22 17"></polygon><polygon points="2 12 12 17 22 12"></polygon></svg>
              Lightroom Milestones & Quality Assurance
            </h4>
            <span class="text-[11px] text-gray-500">Auto-saves to system</span>
          </div>

          <div id="checklistsContainer" class="space-y-4">
            <!-- Dynamic Injection of phase lists -->
          </div>
        </div>

        <!-- COLUMN 2: SYSTEM NOTES & TIMELINE LOG HISTORY -->
        <div class="lg:col-span-5 space-y-6">
          
          <!-- Notes Scratchpad -->
          <div class="bg-lrPanel p-5 rounded-xl border border-lrBorder space-y-3 shadow">
            <h4 class="text-xs font-bold uppercase tracking-wider text-lrMuted flex items-center gap-1.5">
              <svg class="text-emerald-500" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              Catalog Adjustments & Presets
            </h4>
            <textarea
              id="notesArea"
              oninput="updateNotes(this.value)"
              placeholder="Write down presets to synchronize, color-grade notes, specific brush masks, or client adjustments..."
              class="w-full h-32 text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-3 text-white placeholder-gray-600 focus:outline-none focus:border-emerald-500/50 resize-y"
            ></textarea>
            <div class="flex justify-between items-center text-[10px] text-gray-500">
              <span>Saves on keystroke</span>
              <span id="notesCount" class="font-mono">0 characters</span>
            </div>
          </div>

          <!-- Time logs timeline -->
          <div class="bg-lrPanel p-5 rounded-xl border border-lrBorder flex flex-col h-[380px] shadow">
            <div class="flex items-center justify-between pb-3 border-b border-[#22252a] mb-3 shrink-0">
              <h4 class="text-xs font-bold uppercase tracking-wider text-lrMuted flex items-center gap-1.5">
                <svg class="text-indigo-400" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Audited Work History Logs
              </h4>
              <span id="logCounter" class="text-[9px] text-gray-400 bg-slate-800 px-2 py-0.5 rounded font-mono">0 sessions</span>
            </div>

            <!-- Scrollable list of logs -->
            <div id="logsHistoryList" class="flex-1 overflow-y-auto space-y-2.5 pr-1">
              <!-- Logs dynamic generation -->
            </div>
          </div>

        </div>

      </div>

    </main>

  </div>

  <!-- MODAL: CREATE NEW GALLERY -->
  <div id="newGalleryModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 hidden">
    <div class="bg-lrPanel rounded-2xl border border-lrBorder shadow-2xl max-w-md w-full overflow-hidden">
      <div class="px-6 py-4 border-b border-lrBorder flex items-center justify-between bg-lrDarkest">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2">
          <svg class="text-lrBlue" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
          Import New Catalog Gallery
        </h3>
        <button onclick="closeNewGalleryModal()" class="text-gray-400 hover:text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <form onsubmit="handleCreateGallery(event)" class="p-6 space-y-4">
        <div>
          <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Gallery / Shoot Name *</label>
          <input id="newGalName" type="text" required placeholder="e.g. Jenkins Wedding Portfolio" class="w-full text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-lrBlue">
        </div>

        <div>
          <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Client Reference / Event</label>
          <input id="newGalClient" type="text" placeholder="e.g. Jenkins LLC" class="w-full text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-2.5 text-white placeholder-gray-600 focus:outline-none focus:border-lrBlue">
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Photo Count</label>
            <input id="newGalPhotos" type="number" min="1" value="200" class="w-full text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-2.5 text-white focus:outline-none focus:border-lrBlue font-mono">
          </div>
          <div>
            <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Hourly Rate ($)</label>
            <input id="newGalRate" type="number" min="0" value="50" class="w-full text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-2.5 text-white focus:outline-none focus:border-lrBlue font-mono">
          </div>
        </div>

        <div class="pt-4 border-t border-lrBorder flex justify-end gap-2 text-xs">
          <button type="button" onclick="closeNewGalleryModal()" class="px-4 py-2 bg-lrBorder hover:bg-lrBorderLight text-gray-300 rounded-lg">Cancel</button>
          <button type="submit" class="px-4 py-2 bg-lrBlue hover:bg-lrBlueHover text-slate-950 font-bold rounded-lg">Create Catalog</button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL: MANUAL TIME LOG ENTRY -->
  <div id="manualLogModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm p-4 hidden">
    <div class="bg-lrPanel rounded-2xl border border-lrBorder shadow-2xl max-w-md w-full overflow-hidden">
      <div class="px-6 py-4 border-b border-lrBorder flex items-center justify-between bg-lrDarkest">
        <h3 class="text-xs font-bold text-white uppercase tracking-wider flex items-center gap-2">
          <svg class="text-indigo-400" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Log Session Duration manually
        </h3>
        <button onclick="closeManualLogModal()" class="text-gray-400 hover:text-white">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>

      <form onsubmit="handleCreateManualLog(event)" class="p-6 space-y-4">
        <div>
          <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Target Phase</label>
          <select id="manPhase" class="w-full text-xs bg-lrDarkest border border-lrBorderLight rounded-lg p-2.5 text-white focus:outline-none focus:border-lrBlue">
            <option value="import">1. Import & Setup</option>
            <option value="culling">2. Culling / Rating</option>
            <option value="global">3. Global Edits</option>
            <option value="local">4. Local & Masking</option>
            <option value="export">5. Exporting</option>
          </select>
        </div>

        <div>
          <label class="block text-[10px] uppercase font-bold text-lrMuted mb-1">Duration (Minutes)</label>
