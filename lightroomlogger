  <!-- CORE JAVASCRIPT STATE ENGINE -->
  <script>
    // Initialize standard workflow phases definitions
    const PHASES = [
      { id: 'import', name: '1. Import & Setup', color: 'from-sky-500 to-indigo-500', colorText: 'text-sky-400' },
      { id: 'culling', name: '2. Culling / Rating', color: 'from-amber-500 to-orange-500', colorText: 'text-amber-400' },
      { id: 'global', name: '3. Global Edits', color: 'from-emerald-500 to-teal-500', colorText: 'text-emerald-400' },
      { id: 'local', name: '4. Local & Masking', color: 'from-fuchsia-500 to-pink-500', colorText: 'text-fuchsia-400' },
      { id: 'export', name: '5. Exporting', color: 'from-rose-500 to-purple-500', colorText: 'text-rose-400' }
    ];

    // Check if localStorage already contains database, otherwise load premium templates
    let galleries = [];
    
    const DEFAULT_DATA = [
      {
        id: 'g-1',
        name: 'Sarah & Mark - Forest Wedding',
        client: 'Sarah & Mark Jenkins',
        photoCount: 420,
        hourlyRate: 75,
        status: 'In Progress',
        createdAt: new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString(),
        notes: 'Soft, golden-hour lighting. Needs warm presets and heavy masking on the forest-canopy wide shots to bring back skies.',
        checklists: {
          import: [
            { id: 'imp-1', text: 'Generate Smart Previews on import', completed: true },
            { id: 'imp-2', text: 'Apply camera profile & lens corrections automatically', completed: true },
            { id: 'imp-3', text: 'Backup raw files to second SSD', completed: true }
          ],
          culling: [
            { id: 'cul-1', text: 'First-pass speed cull (Reject / Keep)', completed: true },
            { id: 'cul-2', text: 'Star-rate (4-star keepers, 5-star portfolio candidates)', completed: false }
          ],
          global: [
            { id: 'glo-1', text: 'Correct White Balance across sequence', completed: true },
            { id: 'glo-2', text: 'Apply custom tone curves', completed: false }
          ],
          local: [
            { id: 'loc-1', text: 'Brush masking for subject pop in key portraits', completed: false },
            { id: 'loc-2', text: 'Heal background distractions & sensor spots', completed: false }
          ],
          export: [
            { id: 'exp-1', text: 'Output sharp print-res JPEG files', completed: false },
            { id: 'exp-2', text: 'Web-optimized backups with watermarks', completed: false }
          ]
        },
        times: { import: 1240, culling: 3450, global: 2100, local: 1540, export: 0 },
        logs: [
          { id: 'l-1', phase: 'import', duration: 1240, timestamp: new Date(Date.now() - 3 * 24 * 60 * 60 * 1000).toISOString(), note: 'Imported and built Smart Previews.' },
          { id: 'l-2', phase: 'culling', duration: 2400, timestamp: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(), note: 'Initial pass of 800 down to 120.' },
          { id: 'l-3', phase: 'culling', duration: 1050, timestamp: new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString(), note: 'Fine tuning picks.' },
          { id: 'l-4', phase: 'global', duration: 2100, timestamp: new Date(Date.now() - 1 * 24 * 60 * 60 * 1000).toISOString(), note: 'Synced global warmth and profile across selections.' },
          { id: 'l-5', phase: 'local', duration: 1540, timestamp: new Date().toISOString(), note: 'Masked ceremony couple close-ups.' }
        ]
      },
      {
        id: 'g-2',
        name: 'Urban Streetwear Shoot - Downtown',
        client: 'Velo Clothing Co.',
        photoCount: 150,
        hourlyRate: 90,
        status: 'Completed',
        createdAt: new Date(Date.now() - 12 * 24 * 60 * 60 * 1000).toISOString(),
        notes: 'Edgy, high-contrast urban look. Desaturate greens and blues, pump warm yellows/oranges on streetlights.',
        checklists: {
          import: [{ id: 'imp-4', text: 'Import to Lightroom Catalog', completed: true }],
          culling: [{ id: 'cul-3', text: 'Filter down to top 30 key looks', completed: true }],
          global: [{ id: 'glo-3', text: 'Apply high-contrast cinematic profile', completed: true }],
          local: [
            { id: 'loc-3', text: 'Dodge/burn street textures', completed: true },
            { id: 'loc-4', text: 'Clean up skin blemishes on models', completed: true }
          ],
          export: [
            { id: 'exp-3', text: 'Export high-contrast TIFFs for print campaign', completed: true },
            { id: 'exp-4', text: 'Export custom sRGB crops for Instagram Carousel', completed: true }
          ]
        },
        times: { import: 600, culling: 1800, global: 3200, local: 5400, export: 1200 },
        logs: [
          { id: 'l-6', phase: 'import', duration: 600, timestamp: new Date(Date.now() - 10 * 24 * 60 * 60 * 1000).toISOString(), note: 'Import and folder sorting' },
          { id: 'l-7', phase: 'culling', duration: 1800, timestamp: new Date(Date.now() - 10 * 24 * 60 * 60 * 1000).toISOString(), note: 'Pick-flagging with clothes designer' },
          { id: 'l-8', phase: 'global', duration: 3200, timestamp: new Date(Date.now() - 9 * 24 * 60 * 60 * 1000).toISOString(), note: 'Base grading' },
          { id: 'l-9', phase: 'local', duration: 5400, timestamp: new Date(Date.now() - 8 * 24 * 60 * 60 * 1000).toISOString(), note: 'Detailed brush adjustments and skin clean up' },
          { id: 'l-10', phase: 'export', duration: 1200, timestamp: new Date(Date.now() - 8 * 24 * 60 * 60 * 1000).toISOString(), note: 'Multi-spec export completed' }
        ]
      }
    ];

    // Local state tracking variables
    let activeGalleryId = 'g-1';
    let activePhaseId = 'global';
    let isPlaying = false;
    let timeElapsed = 0;
    let timerInterval = null;

    // Load initial data from memory or localStorage
    function loadStorage() {
      const stored = localStorage.getItem('LrWorkflowTracker_DB');
      if (stored) {
        try {
          galleries = JSON.parse(stored);
        } catch (e) {
          galleries = [...DEFAULT_DATA];
        }
      } else {
        galleries = [...DEFAULT_DATA];
        saveStorage();
      }
      
      const storedActive = localStorage.getItem('LrWorkflowTracker_ActiveID');
      if (storedActive && galleries.some(g => g.id === storedActive)) {
        activeGalleryId = storedActive;
      } else if (galleries.length > 0) {
        activeGalleryId = galleries[0].id;
      }
    }

    function saveStorage() {
      localStorage.setItem('LrWorkflowTracker_DB', JSON.stringify(galleries));
      localStorage.setItem('LrWorkflowTracker_ActiveID', activeGalleryId);
    }

    // Helper functions for time conversion formatting
    function formatTime(totalSeconds) {
      const hrs = Math.floor(totalSeconds / 3600);
      const mins = Math.floor((totalSeconds % 3600) / 60);
      const secs = totalSeconds % 60;
      return `${hrs.toString().padStart(2, '0')}:${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
    }

    function formatShortTime(totalSeconds) {
      const hrs = Math.floor(totalSeconds / 3600);
      const mins = Math.floor((totalSeconds % 3600) / 60);
      if (hrs > 0) return `${hrs}h ${mins}m`;
      return `${mins}m`;
    }

    // Timer controls
    function toggleTimer() {
      const btn = document.getElementById('btnPlayPause');
      const icon = document.getElementById('playPauseIcon');
      const saveBtn = document.getElementById('btnSaveTime');
      const resetBtn = document.getElementById('btnResetTimer');
      const dot = document.getElementById('pulsingDot');

      if (!isPlaying) {
        // Start playing
        isPlaying = true;
        btn.className = "p-3.5 rounded-lg bg-amber-500 hover:bg-amber-400 text-slate-950 flex items-center justify-center shadow-lg transition active:scale-95";
        icon.innerHTML = `<rect x="6" y="4" width="4" height="16" rx="1" fill="currentColor"></rect><rect x="14" y="4" width="4" height="16" rx="1" fill="currentColor"></rect>`;
        dot.classList.add('animate-pulse', 'bg-red-500');
        dot.classList.remove('bg-zinc-600');
        
        // Enabled control locks
        saveBtn.disabled = false;
        saveBtn.classList.remove('opacity-40', 'cursor-not-allowed');
        resetBtn.disabled = false;
        resetBtn.classList.remove('text-zinc-700', 'cursor-not-allowed');
        resetBtn.classList.add('text-zinc-400', 'hover:text-white');

        timerInterval = setInterval(() => {
          timeElapsed++;
          updateTimerUI();
        }, 1000);
      } else {
        // Paused state
        isPlaying = false;
        btn.className = "p-3.5 rounded-lg bg-lrBlue hover:bg-lrBlueHover text-slate-950 flex items-center justify-center shadow-lg transition active:scale-95";
        icon.innerHTML = `<polygon points="6 3 20 12 6 21 6 3" fill="currentColor"></polygon>`;
        dot.classList.remove('animate-pulse', 'bg-red-500');
        dot.classList.add('bg-zinc-600');
        
        clearInterval(timerInterval);
      }
    }

    function updateTimerUI() {
      document.getElementById('timerDisplay').innerText = formatTime(timeElapsed);
    }

    function resetTimer() {
      if (confirm("Discard current stopwatch duration?")) {
        stopTimerEngine();
        timeElapsed = 0;
        updateTimerUI();
        renderActiveGallery();
      }
    }

    function stopTimerEngine() {
      if (isPlaying) {
        toggleTimer();
      }
      const saveBtn = document.getElementById('btnSaveTime');
      const resetBtn = document.getElementById('btnResetTimer');
      
      saveBtn.disabled = true;
      saveBtn.classList.add('opacity-40', 'cursor-not-allowed');
      resetBtn.disabled = true;
      resetBtn.classList.add('text-zinc-700', 'cursor-not-allowed');
      resetBtn.classList.remove('text-zinc-400', 'hover:text-white');
    }

    function saveActiveTimerSegment() {
      if (timeElapsed <= 0) return;
      const activePhaseObj = PHASES.find(p => p.id === activePhaseId);
      logTime(activePhaseId, timeElapsed, `Timer capture for ${activePhaseObj.name}`);
      
      timeElapsed = 0;
      updateTimerUI();
      stopTimerEngine();
      renderActiveGallery();
    }

    // Core log tracking interface updater
    function logTime(phaseId, seconds, noteText) {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      activeGal.times[phaseId] = (activeGal.times[phaseId] || 0) + seconds;
      
      const newLog = {
        id: `log-${Date.now()}-${Math.random().toString(36).substr(2, 4)}`,
        phase: phaseId,
        duration: seconds,
        timestamp: new Date().toISOString(),
        note: noteText || 'Standard Segment Log'
      };

      activeGal.logs.unshift(newLog);
      saveStorage();
      renderActiveGallery();
      renderDirectory();
    }

    function changePhase(phaseId) {
      if (isPlaying) {
        // Autosave previous phase timer running
        const activePhaseObj = PHASES.find(p => p.id === activePhaseId);
        logTime(activePhaseId, timeElapsed, `Timer captured due to phase change to: ${PHASES.find(p => p.id === phaseId).name}`);
        timeElapsed = 0;
        updateTimerUI();
        stopTimerEngine();
      }
      activePhaseId = phaseId;
      document.getElementById('timerPhaseTitle').innerText = `${PHASES.find(p => p.id === phaseId).name.toUpperCase()} TIMER`;
      renderActiveGallery();
    }

    // Notes auto-saver
    function updateNotes(text) {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;
      activeGal.notes = text;
      document.getElementById('notesCount').innerText = `${text.length} characters`;
      saveStorage();
    }

    // Checklist interactive toggle handlers
    function toggleChecklistItem(phaseId, taskId) {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;
      
      const targetItem = activeGal.checklists[phaseId].find(item => item.id === taskId);
      if (targetItem) {
        targetItem.completed = !targetItem.completed;
      }
      saveStorage();
      renderActiveGallery();
    }

    function deleteChecklistItem(phaseId, taskId) {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;
      
      activeGal.checklists[phaseId] = activeGal.checklists[phaseId].filter(item => item.id !== taskId);
      saveStorage();
      renderActiveGallery();
    }

    function handleAddChecklistItem(event, phaseId) {
      event.preventDefault();
      const input = document.getElementById(`input-add-${phaseId}`);
      const text = input.value.trim();
      if (!text) return;

      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      const newItem = {
        id: `todo-${Date.now()}`,
        text: text,
        completed: false
      };

      activeGal.checklists[phaseId].push(newItem);
      input.value = '';
      saveStorage();
      renderActiveGallery();
    }

    // Timeline Log Segment Eraser
    function deleteTimelineLog(logId, phaseId, duration) {
      if (confirm("Delete this log segment? The logged duration will be deducted from your workflow times.")) {
        const activeGal = galleries.find(g => g.id === activeGalleryId);
        if (!activeGal) return;

        activeGal.times[phaseId] = Math.max(0, (activeGal.times[phaseId] || 0) - duration);
        activeGal.logs = activeGal.logs.filter(l => l.id !== logId);
        
        saveStorage();
        renderActiveGallery();
        renderDirectory();
      }
    }

    // Modal Control wrappers
    function openNewGalleryModal() {
      document.getElementById('newGalleryModal').classList.remove('hidden');
    }
    function closeNewGalleryModal() {
      document.getElementById('newGalleryModal').classList.add('hidden');
    }

    function openManualLogModal() {
      document.getElementById('manualLogModal').classList.remove('hidden');
    }
    function closeManualLogModal() {
      document.getElementById('manualLogModal').classList.add('hidden');
    }

    function openEditGalleryModal() {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      document.getElementById('editName').value = activeGal.name;
      document.getElementById('editClient').value = activeGal.client;
      document.getElementById('editPhotos').value = activeGal.photoCount;
      document.getElementById('editRate').value = activeGal.hourlyRate;
      document.getElementById('editStatus').value = activeGal.status;

      document.getElementById('editGalleryModal').classList.remove('hidden');
    }
    function closeEditGalleryModal() {
      document.getElementById('editGalleryModal').classList.add('hidden');
    }

    // Form submit handlers
    function handleCreateGallery(event) {
      event.preventDefault();
      const name = document.getElementById('newGalName').value.trim();
      const client = document.getElementById('newGalClient').value.trim() || 'N/A';
      const photos = parseInt(document.getElementById('newGalPhotos').value) || 200;
      const rate = parseInt(document.getElementById('newGalRate').value) || 50;

      if (!name) return;

      const newGal = {
        id: `g-${Date.now()}`,
        name: name,
        client: client,
        photoCount: photos,
        hourlyRate: rate,
        status: 'In Progress',
        createdAt: new Date().toISOString(),
        notes: '',
        checklists: {
          import: [
            { id: `imp-${Date.now()}-1`, text: 'Ingest raw images from card', completed: false },
            { id: `imp-${Date.now()}-2`, text: 'Confirm redundant backup storage sync', completed: false },
            { id: `imp-${Date.now()}-3`, text: 'Build smart previews (1:1 checks)', completed: false }
          ],
          culling: [
            { id: `cul-${Date.now()}-1`, text: 'Perform primary star cull pass (keepers vs rejects)', completed: false },
            { id: `cul-${Date.now()}-2`, text: 'Color label portfolio candidate selections', completed: false }
          ],
          global: [
            { id: `glo-${Date.now()}-1`, text: 'Apply lens profile calibration & CA correction', completed: false },
            { id: `glo-${Date.now()}-2`, text: 'Establish correct reference white balance', completed: false }
          ],
          local: [
            { id: `loc-${Date.now()}-1`, text: 'Heal background spots and sensor dust', completed: false },
            { id: `loc-${Date.now()}-2`, text: 'Generate brush masks to isolate subjects', completed: false }
          ],
          export: [
            { id: `exp-${Date.now()}-1`, text: 'Apply high-pass output sharpening', completed: false },
            { id: `exp-${Date.now()}-2`, text: 'Process batch print sRGB JPEGs to client gallery', completed: false }
          ]
        },
        times: { import: 0, culling: 0, global: 0, local: 0, export: 0 },
        logs: []
      };

      galleries.unshift(newGal);
      activeGalleryId = newGal.id;
      
      saveStorage();
      closeNewGalleryModal();
      
      // Reset input fields
      document.getElementById('newGalName').value = '';
      document.getElementById('newGalClient').value = '';
      
      renderDirectory();
      renderActiveGallery();
    }

    function handleCreateManualLog(event) {
      event.preventDefault();
      const phase = document.getElementById('manPhase').value;
      const minutes = parseInt(document.getElementById('manMinutes').value) || 15;
      const note = document.getElementById('manNote').value.trim();

      const seconds = minutes * 60;
      logTime(phase, seconds, note || `Manually logged ${minutes}m segment`);

      closeManualLogModal();
      document.getElementById('manNote').value = '';
    }

    function handleSaveEditGallery(event) {
      event.preventDefault();
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      activeGal.name = document.getElementById('editName').value.trim();
      activeGal.client = document.getElementById('editClient').value.trim() || 'N/A';
      activeGal.photoCount = parseInt(document.getElementById('editPhotos').value) || 1;
      activeGal.hourlyRate = parseInt(document.getElementById('editRate').value) || 0;
      activeGal.status = document.getElementById('editStatus').value;

      saveStorage();
      closeEditGalleryModal();
      renderActiveGallery();
      renderDirectory();
    }

    function deleteActiveGallery() {
      if (confirm("Permanently delete this catalog gallery? This will clear all logged metadata forever.")) {
        galleries = galleries.filter(g => g.id !== activeGalleryId);
        if (galleries.length > 0) {
          activeGalleryId = galleries[0].id;
        } else {
          // If empty, re-inject fallback
          galleries = [...DEFAULT_DATA];
          activeGalleryId = galleries[0].id;
        }
        stopTimerEngine();
        timeElapsed = 0;
        updateTimerUI();
        saveStorage();
        renderDirectory();
        renderActiveGallery();
      }
    }

    // Direct JSON compiler export to download
    function exportData() {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(activeGal, null, 2));
      const dlAnchor = document.createElement('a');
      dlAnchor.setAttribute("href", dataStr);
      dlAnchor.setAttribute("download", `${activeGal.name.replace(/\s+/g, '_')}_time_logs.json`);
      document.body.appendChild(dlAnchor);
      dlAnchor.click();
      dlAnchor.remove();
    }

    function changeActiveGallery(id) {
      if (id === activeGalleryId) return;
      stopTimerEngine();
      timeElapsed = 0;
      updateTimerUI();
      activeGalleryId = id;
      saveStorage();
      renderDirectory();
      renderActiveGallery();
    }

    // UI RENDER ENGINES
    function renderDirectory() {
      const directory = document.getElementById('galleryDirectory');
      directory.innerHTML = '';

      galleries.forEach(g => {
        // Calculate cumulative times
        const totalTime = Object.values(g.times).reduce((a, b) => a + b, 0);
        const isActive = g.id === activeGalleryId;

        // Build status indicator class
        let statusBadgeClass = "bg-zinc-800 text-zinc-400";
        if (g.status === 'Completed') statusBadgeClass = "bg-emerald-500/15 text-emerald-400";
        if (g.status === 'In Progress') statusBadgeClass = "bg-lrBlue/15 text-lrBlue";

        // Build mini visual micro timeline segments
        let timelineHTML = '';
        PHASES.forEach(p => {
          const value = g.times[p.id] || 0;
          const pct = totalTime > 0 ? (value / totalTime) * 100 : 0;
          let segmentColor = "bg-sky-500";
          if (p.id === 'culling') segmentColor = "bg-amber-500";
          if (p.id === 'global') segmentColor = "bg-emerald-500";
          if (p.id === 'local') segmentColor = "bg-fuchsia-500";
          if (p.id === 'export') segmentColor = "bg-rose-500";

          timelineHTML += `<div style="width: ${pct}%" class="${segmentColor} h-full" title="${p.name}: ${formatShortTime(value)}"></div>`;
        });

        const card = document.createElement('div');
        card.className = `w-full text-left p-3 rounded-lg cursor-pointer transition-all border ${
          isActive 
            ? 'bg-[#1d2229] border-lrBlue/40 shadow-inner' 
            : 'bg-transparent border-transparent hover:bg-lrPanel/40'
        }`;
        card.setAttribute('onclick', `changeActiveGallery('${g.id}')`);

        card.innerHTML = `
          <div class="flex items-start justify-between gap-1 mb-1">
            <span class="text-xs font-bold truncate block ${isActive ? 'text-white' : 'text-gray-300'}">${g.name}</span>
            <span class="text-[9px] px-1.5 py-0.5 rounded-full shrink-0 font-semibold ${statusBadgeClass}">${g.status}</span>
          </div>
          <div class="text-[11px] text-[#767d8a] flex items-center justify-between mt-1">
            <span class="truncate max-w-[120px]">${g.client}</span>
            <span class="flex items-center gap-1 font-mono text-gray-400">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              ${formatShortTime(totalTime)}
            </span>
          </div>
          <div class="mt-2.5 h-1.5 bg-lrBorder rounded-full overflow-hidden flex">
            ${timelineHTML}
          </div>
          <div class="flex items-center justify-between mt-1 text-[9px] text-[#5e6571]">
            <span>${g.photoCount} photos</span>
            <span>${g.logs ? g.logs.length : 0} logs</span>
          </div>
        `;

        directory.appendChild(card);
      });
    }

    function renderActiveGallery() {
      const activeGal = galleries.find(g => g.id === activeGalleryId);
      if (!activeGal) return;

      // Update basic fields
      document.getElementById('activeGalleryIdTag').innerText = `ID: ${activeGal.id}`;
      document.getElementById('activeGalleryName').innerText = activeGal.name;
      document.getElementById('activeGalleryClient').innerText = activeGal.client;
      document.getElementById('activeGalleryPhotos').innerText = `${activeGal.photoCount} Photos`;
      document.getElementById('activeGalleryRate').innerText = `$${activeGal.hourlyRate}/hr`;
      
      // Update Notes scratchpad values
      const notesArea = document.getElementById('notesArea');
      notesArea.value = activeGal.notes || '';
      document.getElementById('notesCount').innerText = `${(activeGal.notes || '').length} characters`;

      // Update Phase selector grid UI elements
      const phasesGrid = document.getElementById('phasesGrid');
      phasesGrid.innerHTML = '';

      PHASES.forEach(p => {
        const isSelected = activePhaseId === p.id;
        const totalDurationForThisPhase = (activeGal.times[p.id] || 0) + (isSelected ? timeElapsed : 0);

        phasesGrid.innerHTML += `
          <button onclick="changePhase('${p.id}')" class="p-2.5 rounded-lg text-left border transition relative flex flex-col justify-between ${
            isSelected 
              ? 'bg-slate-800/85 border-lrBlue/60 text-white shadow-md ring-1 ring-lrBlue/30' 
              : 'bg-[#1b1d22]/80 border-lrBorder hover:border-slate-600 text-gray-400 hover:text-gray-200'
          }">
            <span class="text-[9px] font-bold block truncate">${p.name}</span>
            <div class="flex items-center justify-between mt-2.5">
              <span class="font-mono text-[10px] font-bold text-gray-300">${formatShortTime(totalDurationForThisPhase)}</span>
              <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-tr ${p.color}"></span>
            </div>
          </button>
        `;
      });

      // Update live counter subheadings
      const activePhaseObj = PHASES.find(p => p.id === activePhaseId);
      document.getElementById('segmentTotalDisplay').innerText = formatShortTime((activeGal.times[activePhaseId] || 0) + timeElapsed);

      // Stat Calculations
      const totalTime = Object.values(activeGal.times).reduce((a, b) => a + b, 0) + timeElapsed;
      const earnings = (totalTime / 3600) * activeGal.hourlyRate;
      const avgSeconds = activeGal.photoCount > 0 ? (totalTime / activeGal.photoCount) : 0;
      
      // Complete Tasks Count
      let totalTasksCount = 0;
      let completedTasksCount = 0;
      Object.values(activeGal.checklists).forEach(list => {
        totalTasksCount += list.length;
        completedTasksCount += list.filter(t => t.completed).length;
      });

      // Update Stat DOM values
      document.getElementById('statTotalTime').innerText = formatShortTime(totalTime);
      document.getElementById('statTotalCost').innerText = `$${earnings.toFixed(2)}`;
      document.getElementById('statSpeed').innerText = avgSeconds > 0 ? `${Math.round(avgSeconds)}s / photo` : 'N/A';
      document.getElementById('statTasks').innerText = `${completedTasksCount} / ${totalTasksCount}`;

      // Render Checklists
      const checklistsContainer = document.getElementById('checklistsContainer');
      checklistsContainer.innerHTML = '';

      PHASES.forEach(p => {
        const isSelected = activePhaseId === p.id;
        const phaseTasks = activeGal.checklists[p.id] || [];
        const completedCount = phaseTasks.filter(t => t.completed).length;
        const totalCount = phaseTasks.length;
        const progressPct = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;

        let taskItemsHTML = '';
        if (phaseTasks.length === 0) {
          taskItemsHTML = `<p class="text-xs text-gray-500 italic p-1">No milestones added for this phase.</p>`;
        } else {
          phaseTasks.forEach(task => {
            taskItemsHTML += `
              <div class="flex items-center justify-between p-2 rounded bg-lrDarkest/50 hover:bg-lrDarkest group border border-transparent hover:border-lrBorder transition">
                <div onclick="toggleChecklistItem('${p.id}', '${task.id}')" class="flex items-center space-x-2.5 cursor-pointer flex-1">
                  ${task.completed 
                    ? `<svg class="text-emerald-500 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>`
                    : `<svg class="text-gray-500 hover:text-white shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>`
                  }
                  <span class="text-xs ${task.completed ? 'line-through text-gray-500' : 'text-gray-300'}">${task.text}</span>
                </div>
                <button onclick="deleteChecklistItem('${p.id}', '${task.id}')" class="opacity-0 group-hover:opacity-100 p-1 text-gray-500 hover:text-rose-400 transition" title="Delete milestone">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
              </div>
            `;
          });
        }

        const phaseBox = document.createElement('div');
        phaseBox.className = `rounded-xl border bg-lrPanel overflow-hidden transition ${
          isSelected ? 'border-lrBlue/40 shadow-md ring-1 ring-lrBlue/10' : 'border-lrBorder'
        }`;

        phaseBox.innerHTML = `
          <!-- Phase Box Header -->
          <div class="px-4 py-3 border-b border-[#22252a] flex flex-wrap items-center justify-between gap-2 bg-[#1d1f25]">
            <div class="flex items-center space-x-2.5">
              <div class="w-2.5 h-2.5 rounded-full bg-gradient-to-tr ${p.color}"></div>
              <div>
                <h5 class="text-xs font-bold text-white">${p.name}</h5>
                <div class="text-[10px] text-[#717782] mt-0.5">
                  Cumulative time: <span class="font-mono font-bold text-lrBlue">${formatShortTime((activeGal.times[p.id] || 0) + (isSelected ? timeElapsed : 0))}</span>
                </div>
              </div>
            </div>

            <!-- Horizontal Progress Tracking -->
            <div class="flex items-center space-x-2 min-w-[100px]">
              <div class="w-20 bg-slate-800 h-1.5 rounded-full overflow-hidden">
                <div style="width: ${progressPct}%" class="bg-emerald-500 h-full rounded-full transition-all"></div>
              </div>
              <span class="text-[10px] font-mono font-bold text-gray-300">${progressPct}%</span>
            </div>
          </div>

          <!-- Phase Checklist Body -->
          <div class="p-3.5 space-y-2">
            <div class="space-y-1">${taskItemsHTML}</div>

            <!-- Custom task add interface -->
            <form onsubmit="handleAddChecklistItem(event, '${p.id}')" class="flex items-center gap-2 mt-3 pt-3 border-t border-[#22252a]">
              <input
                id="input-add-${p.id}"
                type="text"
                placeholder="Add custom Lightroom checklist task..."
                class="flex-1 text-xs bg-lrDarkest border border-lrBorderLight rounded px-2.5 py-1.5 text-white placeholder-gray-600 focus:outline-none focus:border-lrBlue/50"
              >
              <button type="submit" class="p-1.5 rounded bg-lrBorder hover:bg-lrBlue hover:text-slate-950 text-gray-400 transition" title="Add milestone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              </button>
            </form>
          </div>
        `;

        checklistsContainer.appendChild(phaseBox);
      });

      // Render Time log history items
      const logsHistoryList = document.getElementById('logsHistoryList');
      const logCounter = document.getElementById('logCounter');
      logsHistoryList.innerHTML = '';
      
      const logs = activeGal.logs || [];
      logCounter.innerText = `${logs.length} logged sessions`;

      if (logs.length === 0) {
        logsHistoryList.innerHTML = `
          <div class="h-full flex flex-col items-center justify-center text-center p-4 mt-8">
            <svg class="text-zinc-600 mb-2" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            <p class="text-xs text-gray-400 font-semibold">No time segments logged yet</p>
            <p class="text-[10px] text-zinc-500 mt-1 max-w-[180px]">Run the live timer engine or log times manually to populate workspace analytics.</p>
          </div>
        `;
      } else {
        logs.forEach(log => {
          const logPhaseObj = PHASES.find(p => p.id === log.phase) || PHASES[0];
          const timeStr = new Date(log.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
          const dateStr = new Date(log.timestamp).toLocaleDateString();

          const logItem = document.createElement('div');
          logItem.className = 'bg-lrDarkest p-3 rounded-lg border border-lrBorder flex items-start justify-between gap-2 hover:border-[#2b303a] transition';
          
          logItem.innerHTML = `
            <div class="space-y-1 flex-1 min-w-0">
              <div class="flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-gradient-to-tr ${logPhaseObj.color}"></span>
                <span class="text-[10px] font-bold text-gray-300 uppercase truncate">${logPhaseObj.name.replace(/^\d+\.\s+/, '')}</span>
                <span class="text-[9px] text-gray-500 font-mono">${timeStr}</span>
              </div>
              <p class="text-xs text-gray-400 font-light truncate" title="${log.note || ''}">
                "${log.note || 'No description'}"
              </p>
              <div class="text-[9px] text-gray-500">
                Date: ${dateStr}
              </div>
            </div>
            <div class="flex flex-col items-end gap-1 shrink-0">
              <span class="font-mono text-xs font-bold text-emerald-400">+${formatShortTime(log.duration)}</span>
              <button onclick="deleteTimelineLog('${log.id}', '${log.phase}', ${log.duration})" class="text-gray-600 hover:text-rose-400 p-0.5 rounded transition" title="Delete log">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
          `;

          logsHistoryList.appendChild(logItem);
        });
      }
    }

    // Initialize application systems on document load
    window.onload = function() {
      loadStorage();
      renderDirectory();
      renderActiveGallery();
    };
  </script>

</body>
</html>
